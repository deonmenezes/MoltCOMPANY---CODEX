{
  "name": "moltcompany",
  "version": "0.2.0",
  "description": "Lightweight TypeScript SDK, CLI, and MCP bridge for MoltCompany task pickup, onboarding links, and OpenClaw handoff.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "moltcompany": "./dist/cli.js",
    "moltcompany-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "homepage": "https://www.moltcompany.ai/install",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deonmenezes/moltcompany.git"
  },
  "bugs": {
    "url": "https://github.com/deonmenezes/moltcompany/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "pretest": "npm run build",
    "test": "node --test test/*.test.mjs",
    "pack:check": "npm pack --json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.3",
    "zod": "^3.24.1"
  },
  "keywords": [
    "clawhub",
    "onboarding",
    "ai-agent",
    "moltcompany",
    "mcp",
    "openclaw",
    "typescript",
    "cli",
    "bun",
    "npm"
  ],
  "license": "MIT"
}
